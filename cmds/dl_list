def download(ent, dl=False):
	if not dl:
		print('Skip download: %s' % (ent.get('name'),))
		return

	ydl_opts = {
		'outtmpl': {
			'default': ent.get('name'),
			'pl_thumbnail': ''
		},
		'paths': {
			'home': dl_dir
		},
		'postprocessors': [
			{
				'actions': [
								(
									yt_dlp.postprocessor.metadataparser.MetadataParserPP.interpretter,
									ent.get('name'),
									'(?P<meta_title>.*) -'
									),
								(
									yt_dlp.postprocessor.metadataparser.MetadataParserPP.interpretter,
									ent.get('name'),
									'.*- (?P<meta_artist>.*)'
									),
